<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= @page_title %></title>
    <link rel="stylesheet" href="/static/app.css">
</head>
<body class='bg-neutral text-stone-900'>
