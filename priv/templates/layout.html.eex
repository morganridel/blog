        <a href="/" class="text-2xl text-primary">Morgan Ridel</h1>
        <a href="/" class="text-xl text-secondary">Blog</h1>
        <a href="/about" class="text-xl text-secondary">About</h1>
    </header>
    <main class="page flow flow-xl">
        <%= @inner_content %>
    </main>
</body>
</html>
