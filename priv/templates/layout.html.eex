<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= @page_title %></title>
    <link rel="stylesheet" href="/static/app.css">
</head>
<body>
    <header class="bg-gray-800 text-white p-4">
        <h1 class="text-2xl font-bold">My Elixir Blog</h1>
    </header>
    <main class="container mx-auto p-4">
        <%= @inner_content %>
    </main>
    <footer class="bg-gray-200 p-4 text-center text-red-400">
        &copy; 2023 My Elixir SSG
    </footer>
</body>
</html>
